# Climate Digital Twin - Frontend Configuration
# Copy this file to .env.local for local development.

# ----------------------------------------------------
# API Connectivity (Supabase / Render Backend)
# ----------------------------------------------------
# Base URL for the FastAPI Backend REST endpoints
NEXT_PUBLIC_API_URL="http://localhost:8000/api/v1"

# Base URL for the FastAPI Backend WebSocket endpoints
NEXT_PUBLIC_WS_URL="ws://localhost:8000/api/v1/ws"

# ----------------------------------------------------
# Application Identity
# ----------------------------------------------------
NEXT_PUBLIC_APP_NAME="Climate Digital Twin"
NEXT_PUBLIC_ENVIRONMENT="development"

# ----------------------------------------------------
# GIS & Mapping Configuration
# ----------------------------------------------------
# Style URL for MapLibre GL
NEXT_PUBLIC_MAP_STYLE="https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json"

# ----------------------------------------------------
# Feature Flags & Analytics
# ----------------------------------------------------
NEXT_PUBLIC_ENABLE_ANALYTICS="false"
